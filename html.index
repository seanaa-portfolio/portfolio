<!-- ✅ مودال ویدیو -->
<div class="video-modal" id="videoModal">
<div class="modal-video-container">
<button class="close-modal" id="closeModal">×</button>
<!-- ✅ FIX: Removed 'muted' attribute from HTML, handled dynamically in JS for better audio support -->
<video id="modalVideo" controls playsinline></video>
<div class="modal-title" id="modalTitle"></div>
</div>
</div>
<!-- ✅ مودال تصویر -->
<div class="image-modal" id="imageModal">
<div class="modal-image-container">
<button class="close-modal" id="closeImageModal">×</button>
<img id="modalImage" src="" alt="">
<div class="modal-title" id="modalImageTitle"></div>
<div class="zoom-controls">
<button id="zoomIn" title="بزرگنمایی">+</button>
<button id="zoomOut" title="کوچکنمایی">-</button>
<button id="resetZoom" title="بازنشانی">⟲</button>
</div>
</div>
</div>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
if (!isTouchDevice) {
document.querySelectorAll('.slide-media').forEach(media => {
if (media.tagName === 'VIDEO') {
media.pause();
}
});
}
document.querySelectorAll('.swiper-frame').forEach((frame) => {
const swiperContainer = frame.querySelector('.blogix-swiper');
const nextEl = frame.querySelector('.swiper-button-next');
const prevEl = frame.querySelector('.swiper-button-prev');
const paginationEl = frame.querySelector('.swiper-pagination');
const swiper = new Swiper(swiperContainer, {
rtl: false,
loop: true,
grabCursor: true,
direction: 'horizontal',
slidesPerView: 1,
spaceBetween: 0,
speed: 600,
navigation: { nextEl: nextEl, prevEl: prevEl },
pagination: {
el: paginationEl,
clickable: true,
type: 'bullets',
bulletClass: 'swiper-pagination-bullet',
bulletActiveClass: 'swiper-pagination-bullet-active'
},
observer: true,
observeParents: true,
on: {
init: function() { playActiveMedia(this, frame); },
slideChangeTransitionStart: function() { pauseAllMedia(frame); },
slideChangeTransitionEnd: function() { playActiveMedia(this, frame); }
}
});
function playActiveMedia(swiperInstance, currentFrame) {
currentFrame.querySelectorAll('.slide-media').forEach(media => {
if (media.tagName === 'VIDEO') {
media.pause();
media.preload = 'metadata';
}
});
const activeSlide = swiperInstance.slides[swiperInstance.activeIndex];
if (activeSlide) {
const media = activeSlide.querySelector('.slide-media');
if (media && media.tagName === 'VIDEO') {
media.muted = true;
media.preload = 'auto';
try { media.load(); } catch(e) {}
const playPromise = media.play();
if (playPromise !== undefined) {
playPromise.catch(() => {
setTimeout(() => {
media.play().catch(() => {});
}, 100);
});
}
}
}
}
function pauseAllMedia(currentFrame) {
currentFrame.querySelectorAll('.slide-media').forEach(media => {
if (media.tagName === 'VIDEO') media.pause();
});
}
if (!isTouchDevice) {
const slides = frame.querySelectorAll('.swiper-slide');
slides.forEach(slide => {
slide.addEventListener('mouseenter', () => {
const media = slide.querySelector('.slide-media');
if (media && media.tagName === 'VIDEO' && media.paused) {
media.muted = true;
media.preload = 'auto';
try { media.load(); } catch(e) {}
media.play().catch(() => {});
}
});
slide.addEventListener('mouseleave', () => {
const media = slide.querySelector('.slide-media');
if (media && media.tagName === 'VIDEO' && !slide.classList.contains('swiper-slide-active')) {
media.pause();
}
});
});
}
});
const videoModal = document.getElementById('videoModal');
const modalVideo = document.getElementById('modalVideo');
const modalTitle = document.getElementById('modalTitle');
const closeModalBtn = document.getElementById('closeModal');
const imageModal = document.getElementById('imageModal');
const modalImage = document.getElementById('modalImage');
const modalImageTitle = document.getElementById('modalImageTitle');
const closeImageModalBtn = document.getElementById('closeImageModal');
const zoomInBtn = document.getElementById('zoomIn');
const zoomOutBtn = document.getElementById('zoomOut');
const resetZoomBtn = document.getElementById('resetZoom');
let currentZoom = 1;
let isPanning = false;
let startX = 0, startY = 0;
let translateX = 0, translateY = 0;
function updateTransform() {
modalImage.style.transform = `translate(${translateX}px, ${translateY}px) scale(${currentZoom})`;
}
document.querySelectorAll('.swiper-frame').forEach(frame => {
frame.addEventListener('click', (e) => {
if (e.target.closest('.swiper-button-prev') || e.target.closest('.swiper-button-next') || e.target.closest('.swiper-pagination')) {
return;
}
const slide = e.target.closest('.swiper-slide');
if (!slide) return;
const src = slide.getAttribute('data-src');
const titleText = slide.getAttribute('data-title');
if (frame.classList.contains('image-slider')) {
if (src) {
modalImage.src = src;
modalImageTitle.innerText = titleText || '';
currentZoom = 1;
translateX = 0;
translateY = 0;
updateTransform();
modalImage.style.cursor = 'zoom-in';
imageModal.style.display = 'flex';
// ✅ FIX: Robust Scroll Locking
document.body.style.overflow = 'hidden';
document.documentElement.style.overflow = 'hidden';
setTimeout(() => { imageModal.classList.add('active'); }, 10);
}
} else {
if (src) {
modalVideo.src = src;
modalTitle.innerText = titleText || '';
videoModal.style.display = 'flex';
// ✅ FIX: Robust Scroll Locking
document.body.style.overflow = 'hidden';
document.documentElement.style.overflow = 'hidden';
// ✅ FIX: Moved play() outside setTimeout to keep user gesture context for unmuted autoplay
modalVideo.muted = false;
const playPromise = modalVideo.play();
if (playPromise !== undefined) {
playPromise.catch(err => {
console.log("پخش با صدا مسدود شد، تلاش برای پخش بی‌صدا:", err);
modalVideo.muted = true;
modalVideo.play().catch(() => {});
});
}
setTimeout(() => {
videoModal.classList.add('active');
}, 10);
}
}
});
});
function closeVideoModal() {
videoModal.classList.remove('active');
modalVideo.pause();
// ✅ FIX: Restore Scroll
document.body.style.overflow = '';
document.documentElement.style.overflow = '';
setTimeout(() => {
modalVideo.removeAttribute('src');
modalVideo.load();
videoModal.style.display = 'none';
modalTitle.innerText = "";
}, 300);
}
closeModalBtn.addEventListener('click', closeVideoModal);
videoModal.addEventListener('click', (e) => { if (e.target === videoModal) closeVideoModal(); });
function closeImageModalFunc() {
imageModal.classList.remove('active');
// ✅ FIX: Restore Scroll
document.body.style.overflow = '';
document.documentElement.style.overflow = '';
setTimeout(() => {
modalImage.removeAttribute('src');
imageModal.style.display = 'none';
modalImageTitle.innerText = "";
currentZoom = 1;
translateX = 0;
translateY = 0;
updateTransform();
modalImage.style.cursor = 'zoom-in';
}, 300);
}
closeImageModalBtn.addEventListener('click', closeImageModalFunc);
imageModal.addEventListener('click', (e) => { if (e.target === imageModal) closeImageModalFunc(); });
modalImage.addEventListener('mousedown', (e) => {
if (currentZoom > 1) {
isPanning = true;
startX = e.clientX - translateX;
startY = e.clientY - translateY;
modalImage.style.cursor = 'grabbing';
modalImage.style.transition = 'none';
e.preventDefault();
}
});
document.addEventListener('mousemove', (e) => {
if (isPanning) {
e.preventDefault();
translateX = e.clientX - startX;
translateY = e.clientY - startY;
updateTransform();
}
});
document.addEventListener('mouseup', () => {
if (isPanning) {
isPanning = false;
modalImage.style.transition = 'transform 0.3s ease';
modalImage.style.cursor = currentZoom > 1 ? 'grab' : 'zoom-in';
}
});
modalImage.addEventListener('touchstart', (e) => {
if (currentZoom > 1 && e.touches.length === 1) {
isPanning = true;
startX = e.touches[0].clientX - translateX;
startY = e.touches[0].clientY - translateY;
modalImage.style.transition = 'none';
e.preventDefault();
}
}, { passive: false });
document.addEventListener('touchmove', (e) => {
if (isPanning && e.touches.length === 1) {
e.preventDefault();
translateX = e.touches[0].clientX - startX;
translateY = e.touches[0].clientY - startY;
updateTransform();
}
}, { passive: false });
document.addEventListener('touchend', () => {
if (isPanning) {
isPanning = false;
modalImage.style.transition = 'transform 0.3s ease';
}
});
if (zoomInBtn) {
zoomInBtn.addEventListener('click', (e) => {
e.stopPropagation();
if (currentZoom < 3) {
currentZoom += 0.5;
updateTransform();
modalImage.style.cursor = 'grab';
}
});
}
if (zoomOutBtn) {
zoomOutBtn.addEventListener('click', (e) => {
e.stopPropagation();
if (currentZoom > 1) {
currentZoom -= 0.5;
updateTransform();
if (currentZoom === 1) {
translateX = 0;
translateY = 0;
updateTransform();
modalImage.style.cursor = 'zoom-in';
} else {
modalImage.style.cursor = 'grab';
}
}
});
}
if (resetZoomBtn) {
resetZoomBtn.addEventListener('click', (e) => {
e.stopPropagation();
currentZoom = 1;
translateX = 0;
translateY = 0;
updateTransform();
modalImage.style.cursor = 'zoom-in';
});
}
modalImage.addEventListener('click', (e) => {
e.stopPropagation();
if (currentZoom === 1) {
currentZoom = 2;
updateTransform();
modalImage.style.cursor = 'grab';
} else {
currentZoom = 1;
translateX = 0;
translateY = 0;
updateTransform();
modalImage.style.cursor = 'zoom-in';
}
});
document.addEventListener('keydown', (e) => {
if (e.key === 'Escape') {
if (videoModal.classList.contains('active')) closeVideoModal();
if (imageModal.classList.contains('active')) closeImageModalFunc();
}
});
});
</script>
</body>
</html>
